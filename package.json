{
	"name": "@sourceregistry/sveltekit-service-manager",
	"version": "2.0.4",
	"description": "A minimal, production-oriented service gateway for SvelteKit.",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"docs:build": "typedoc src/lib/client/index.ts src/lib/server/index.ts src/lib/index.ts --out generated/docs --name \"sveltekit-service-manager\" --theme default --excludePrivate --excludeProtected --entryPointStrategy expand"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/server/index.d.ts",
			"import": "./dist/server/index.js"
		},
		"./server": {
			"types": "./dist/server/index.d.ts",
			"import": "./dist/server/index.js"
		},
		"./client": {
			"types": "./dist/client/index.d.ts",
			"import": "./dist/client/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@semantic-release/changelog": "6.0.3",
		"@semantic-release/commit-analyzer": "13.0.1",
		"@semantic-release/git": "10.0.1",
		"@semantic-release/npm": "13.1.5",
		"@semantic-release/release-notes-generator": "14.1.1",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/kit": "2.60.1",
		"@sveltejs/package": "2.5.7",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@types/node": "25.8.0",
		"@vitest/browser-playwright": "4.1.6",
		"@vitest/coverage-v8": "4.1.6",
		"playwright": "1.60.0",
		"publint": "0.3.21",
		"svelte": "5.55.7",
		"svelte-check": "4.4.8",
		"typedoc": "0.28.19",
		"typescript": "6.0.3",
		"vite": "8.0.13",
		"vitest": "4.1.6",
		"vitest-browser-svelte": "2.1.1"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SourceRegistry/sveltekit-service-manager.git"
	},
	"keywords": [
		"services",
		"service",
		"microservice",
		"microservices",
		"service-manager",
		"sveltekit-service-manager"
	],
	"author": "A.P.A. Slaa (a.p.a.slaa@projectsource.nl)",
	"license": "Apache-2.0",
	"homepage": "https://sourceregistry.github.io/sveltekit-service-manager/",
	"bugs": {
		"url": "https://github.com/SourceRegistry/sveltekit-service-manager/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": "^20.19.0 || ^22.12.0 || >=24.0.0"
	},
	"release": {
		"branches": [
			"main"
		],
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			"@semantic-release/changelog",
			"@semantic-release/npm",
			[
				"@semantic-release/git",
				{
					"assets": [
						"package.json",
						"CHANGELOG.md"
					],
					"message": "sveltekit-service-manager(release): 🚀 v${nextRelease.version}\n\n${nextRelease.notes}"
				}
			]
		]
	},
	"dependencies": {
		"cookie": "1.1.1"
	},
	"overrides": {
		"cookie": "1.1.1",
		"npm": "11.14.1"
	}
}
